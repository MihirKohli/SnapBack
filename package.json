{
  "name": "snapback",
  "displayName": "SnapBack",
  "description": "Persistent, cross-restart undo/redo history (up to N snapshots per file) stored on disk.",
  "version": "0.0.1",
  "publisher": "mihir",
  "repository": { "type": "git", "url": "https://github.com/mihir/snapback" },
  "license": "MIT",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",

  "contributes": {
    "commands": [
      {
        "command": "snapback.undo",
        "title": "SnapBack Undo",
        "category": "SnapBack"
      },
      {
        "command": "snapback.redo",
        "title": "SnapBack Redo",
        "category": "SnapBack"
      },
      {
        "command": "snapback.showHistory",
        "title": "Show History & Stats",
        "category": "SnapBack"
      },
      {
        "command": "snapback.clearFile",
        "title": "Clear History for This File",
        "category": "SnapBack"
      },
      {
        "command": "snapback.clearAll",
        "title": "Clear ALL Persistent History",
        "category": "SnapBack"
      }
    ],

    "keybindings": [
      {
        "command": "snapback.undo",
        "key": "ctrl+z",
        "mac": "cmd+z",
        "when": "editorTextFocus"
      },
      {
        "command": "snapback.redo",
        "key": "ctrl+y",
        "mac": "cmd+shift+z",
        "when": "editorTextFocus"
      }
    ],

    "configuration": {
      "title": "SnapBack",
      "properties": {
        "snapback.maxHistory": {
          "type": "number",
          "default": 500,
          "minimum": 1,
          "maximum": 50000,
          "description": "Maximum undo/redo snapshots stored per file. Each snapshot is the full file text at that moment — large files at high values will consume significant disk space."
        }
      }
    },

    "menus": {
      "editor/context": [
        {
          "submenu": "snapback.submenu",
          "group": "1_modification"
        }
      ],
      "snapback.submenu": [
        { "command": "snapback.undo" },
        { "command": "snapback.redo" },
        { "command": "snapback.showHistory" },
        { "command": "snapback.clearFile" },
        { "command": "snapback.clearAll" }
      ]
    },

    "submenus": [
      {
        "id": "snapback.submenu",
        "label": "SnapBack"
      }
    ]
  },

  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },

  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
