{
  "name": "return-back",
  "displayName": "Return Back",
  "description": "Persistent, cross-restart undo/redo history (up to N snapshots per file) stored on disk.",
  "version": "0.0.1",
  "publisher": "MihirKohli",
  "repository": { "type": "git", "url": "https://github.com/mihir/return-back" },
  "license": "MIT",
  "engines": { "vscode": "^1.85.0" },
  "icon": "icon.png",
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",

  "contributes": {
    "commands": [
      {
        "command": "returnBack.undo",
        "title": "Return Back Undo",
        "category": "Return Back"
      },
      {
        "command": "returnBack.redo",
        "title": "Return Back Redo",
        "category": "Return Back"
      },
      {
        "command": "returnBack.showHistory",
        "title": "Show History & Stats",
        "category": "Return Back"
      },
      {
        "command": "returnBack.clearFile",
        "title": "Clear History for This File",
        "category": "Return Back"
      },
      {
        "command": "returnBack.clearAll",
        "title": "Clear ALL Persistent History",
        "category": "Return Back"
      }
    ],

    "keybindings": [
      {
        "command": "returnBack.undo",
        "key": "ctrl+z",
        "mac": "cmd+z",
        "when": "editorTextFocus"
      },
      {
        "command": "returnBack.redo",
        "key": "ctrl+y",
        "mac": "cmd+shift+z",
        "when": "editorTextFocus"
      }
    ],

    "configuration": {
      "title": "Return Back",
      "properties": {
        "returnBack.maxHistory": {
          "type": "number",
          "default": 500,
          "minimum": 1,
          "maximum": 50000,
          "description": "Maximum undo/redo snapshots stored per file. Each snapshot is the full file text at that moment — large files at high values will consume significant disk space."
        }
      }
    },

    "menus": {
      "editor/context": [
        {
          "submenu": "returnBack.submenu",
          "group": "1_modification"
        }
      ],
      "returnBack.submenu": [
        { "command": "returnBack.undo" },
        { "command": "returnBack.redo" },
        { "command": "returnBack.showHistory" },
        { "command": "returnBack.clearFile" },
        { "command": "returnBack.clearAll" }
      ]
    },

    "submenus": [
      {
        "id": "returnBack.submenu",
        "label": "Return Back"
      }
    ]
  },

  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },

  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^3.9.1"
  }
}
